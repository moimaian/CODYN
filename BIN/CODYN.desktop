#!/usr/bin/env xdg-open

[Desktop Entry]
Version=2025.1
Name=CODYN
Comment=AUTOMATIZED MOLECULAR DYNAMICS TOOL
Exec=python3 $HOME/CODYN/CODYN.py
Icon=$HOME/CODYN/ICONS/LOGO_CODYN.png
Terminal=false
Type=Application
Categories=Qt;Science;Chemistry;Physics;Education;
StartupNotify=true
MimeType=chemical/x-cml;chemical/x-xyz;

Name[pt_BR]=CODYN.desktop
